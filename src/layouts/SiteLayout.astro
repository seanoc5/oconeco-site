---
interface Props {
  title: string;
  description?: string;
  mainClass?: string;
  isArticle?: boolean;
}
const { title, description, mainClass = "", isArticle = false } = Astro.props;
const pageTitle = title === "Oconeco" ? "OconEco" : `${title} — OconEco`;

const cfBeaconToken = import.meta.env.PUBLIC_CF_BEACON_TOKEN;
const enableAnalytics = import.meta.env.PROD && cfBeaconToken;

const SITE_URL = "https://oconeco.com";
const ORG_ID = `${SITE_URL}/#organization`;
const WEBSITE_ID = `${SITE_URL}/#website`;
const ORG_DESCRIPTION =
  "OconEco builds IT workspaces that surface local economic intelligence — a smart grid for resource-allocation decisions across multiple scales.";

const pagePath = Astro.url.pathname;
const canonicalUrl = new URL(pagePath, SITE_URL).toString();

const orgJsonLd = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "@id": ORG_ID,
  name: "OconEco",
  url: SITE_URL,
  description: ORG_DESCRIPTION,
  sameAs: [],
};

const websiteJsonLd = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "@id": WEBSITE_ID,
  url: SITE_URL,
  name: "OconEco",
  inLanguage: "en",
  publisher: { "@id": ORG_ID },
};

function humanize(segment: string): string {
  const spaced = segment.replace(/-/g, " ");
  return spaced.charAt(0).toUpperCase() + spaced.slice(1);
}

const trimmedPath = pagePath.replace(/^\/|\/$/g, "");
const segments = trimmedPath ? trimmedPath.split("/") : [];
const breadcrumbItems = [
  {
    "@type": "ListItem",
    position: 1,
    name: "Home",
    item: `${SITE_URL}/`,
  },
  ...segments.map((seg, i) => ({
    "@type": "ListItem",
    position: i + 2,
    name: humanize(seg),
    item: `${SITE_URL}/${segments.slice(0, i + 1).join("/")}/`,
  })),
];

const breadcrumbJsonLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: breadcrumbItems,
};

const articleJsonLd = isArticle
  ? {
      "@context": "https://schema.org",
      "@type": "Article",
      headline: title,
      ...(description ? { description } : {}),
      url: canonicalUrl,
      mainEntityOfPage: canonicalUrl,
      inLanguage: "en",
      publisher: { "@id": ORG_ID },
      isPartOf: { "@id": WEBSITE_ID },
    }
  : null;

const nav = [
  { href: "/", label: "Home" },
  { href: "/our-services/", label: "Service levels" },
  { href: "/ot/", label: "Toolkit" },
  { href: "/about-you/", label: "Adding value" },
  { href: "/reference-materials/", label: "Reference" },
  { href: "/about-us/", label: "About us" },
  { href: "/contact/", label: "Contact" },
];

const currentPath = Astro.url.pathname.replace(/\/$/, "") || "/";
function isCurrent(href: string): boolean {
  const normalized = href.replace(/\/$/, "") || "/";
  if (normalized === "/") return currentPath === "/";
  return currentPath === normalized || currentPath.startsWith(normalized + "/");
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    {description && <meta name="description" content={description} />}
    <title>{pageTitle}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Source+Serif+4:ital,opsz,wght@0,8..60,400;0,8..60,600;1,8..60,400&display=swap"
    />
    <link rel="stylesheet" href="/styles/site.css" />
    <script type="application/ld+json" set:html={JSON.stringify(orgJsonLd)} />
    <script type="application/ld+json" set:html={JSON.stringify(websiteJsonLd)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbJsonLd)} />
    {articleJsonLd && (
      <script type="application/ld+json" set:html={JSON.stringify(articleJsonLd)} />
    )}
    {enableAnalytics && (
      <script
        defer
        src="https://static.cloudflareinsights.com/beacon.min.js"
        data-cf-beacon={`{"token": "${cfBeaconToken}"}`}
      />
    )}
  </head>
  <body>
    <header class="site-header">
      <div class="site-header-inner">
        <a class="brand" href="/">Ocon<span class="brand-mark">Eco</span></a>
        <nav class="site-nav" aria-label="Primary">
          <ul>
            {nav.map((item) => (
              <li>
                <a
                  href={item.href}
                  aria-current={isCurrent(item.href) ? "page" : undefined}
                >
                  {item.label}
                </a>
              </li>
            ))}
          </ul>
        </nav>
      </div>
    </header>
    <slot name="hero" />
    <main class={`site-main ${mainClass}`}>
      <slot />
    </main>
    <footer class="site-footer">
      <div class="site-footer-inner">
        <p>&copy; {new Date().getFullYear()} OconEco. All rights reserved.</p>
        <p>
          <a href="/site-map/">Site map</a>
          &nbsp;·&nbsp;
          <a href="/contact/">Contact</a>
        </p>
      </div>
    </footer>
  </body>
</html>
