---
interface Props {
  title: string;
  description?: string;
  mainClass?: string;
}
const { title, description, mainClass = "" } = Astro.props;
const pageTitle = title === "Oconeco" ? "OconEco" : `${title} — OconEco`;

const cfBeaconToken = import.meta.env.PUBLIC_CF_BEACON_TOKEN;
const enableAnalytics = import.meta.env.PROD && cfBeaconToken;

const nav = [
  { href: "/", label: "Home" },
  { href: "/our-services/", label: "Service levels" },
  { href: "/ot/", label: "Toolkit" },
  { href: "/about-you/", label: "Adding value" },
  { href: "/reference-materials/", label: "Reference" },
  { href: "/about-us/", label: "About us" },
  { href: "/contact/", label: "Contact" },
];

const currentPath = Astro.url.pathname.replace(/\/$/, "") || "/";
function isCurrent(href: string): boolean {
  const normalized = href.replace(/\/$/, "") || "/";
  if (normalized === "/") return currentPath === "/";
  return currentPath === normalized || currentPath.startsWith(normalized + "/");
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    {description && <meta name="description" content={description} />}
    <title>{pageTitle}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Source+Serif+4:ital,opsz,wght@0,8..60,400;0,8..60,600;1,8..60,400&display=swap"
    />
    <link rel="stylesheet" href="/styles/site.css" />
    {enableAnalytics && (
      <script
        defer
        src="https://static.cloudflareinsights.com/beacon.min.js"
        data-cf-beacon={`{"token": "${cfBeaconToken}"}`}
      />
    )}
  </head>
  <body>
    <header class="site-header">
      <div class="site-header-inner">
        <a class="brand" href="/">Ocon<span class="brand-mark">Eco</span></a>
        <nav class="site-nav" aria-label="Primary">
          <ul>
            {nav.map((item) => (
              <li>
                <a
                  href={item.href}
                  aria-current={isCurrent(item.href) ? "page" : undefined}
                >
                  {item.label}
                </a>
              </li>
            ))}
          </ul>
        </nav>
      </div>
    </header>
    <slot name="hero" />
    <main class={`site-main ${mainClass}`}>
      <slot />
    </main>
    <footer class="site-footer">
      <div class="site-footer-inner">
        <p>&copy; {new Date().getFullYear()} OconEco. All rights reserved.</p>
        <p>
          <a href="/site-map/">Site map</a>
          &nbsp;·&nbsp;
          <a href="/contact/">Contact</a>
        </p>
      </div>
    </footer>
  </body>
</html>
